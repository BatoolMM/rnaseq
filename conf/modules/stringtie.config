process {
    // Final quantification against the reference GTF (default) or the
    // BAM_STRINGTIE_MERGE merged annotation (when --stringtie_ignore_gtf).
    withName: 'STRINGTIE_STRINGTIE' {
        ext.args = { ['-v', '-e'].join(' ').trim() }
        publishDir = [
            path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/stringtie" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Per-sample de novo assembly inside BAM_STRINGTIE_MERGE.
    // `.denovo` prefix prevents filename collision with the final
    // quantification step, which also emits <id>.transcripts.gtf.
    // Only publish the assembled GTF: abundance/coverage/ballgown from
    // this step are against per-sample assemblies and not comparable
    // across samples (those come from the quantification step above).
    withName: 'NFCORE_RNASEQ:RNASEQ:BAM_STRINGTIE_MERGE:STRINGTIE_STRINGTIE' {
        ext.args   = { "-v" }
        ext.prefix = { "${meta.id}.denovo" }
        publishDir = [
            path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/stringtie" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                if (filename.endsWith('.transcripts.gtf')) return filename
                return null
            }
        ]
    }

    // Cross-sample merged annotation produced by `stringtie --merge`.
    withName: 'NFCORE_RNASEQ:RNASEQ:BAM_STRINGTIE_MERGE:STRINGTIE_MERGE' {
        publishDir = [
            path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/stringtie" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
