process {

    // Bowtie2 alignment configuration
    // Bowtie2 is a splice-unaware aligner suitable for prokaryotic RNA-seq.
    //
    // For the bowtie2_salmon aligner, Bowtie2 writes to the transcriptome.
    // Salmon's downstream alignment-mode EM needs multiple candidate
    // alignments per read to resolve reads that map to overlapping transcripts
    // (e.g. operon-associated gene overlaps in bacteria); with the Bowtie2
    // default of reporting a single best alignment, such reads are force-
    // assigned to one transcript and the EM has nothing to redistribute.
    // `-k ${params.bowtie2_align_k}` tells Bowtie2 to search for and report
    // up to N alignments per read. The default of 200 matches:
    //   - the Salmon paper's benchmark settings (Patro et al. 2017, Nat. Methods,
    //     Methods/Software versions: "Reads were aligned with Bowtie2 using the
    //     parameters --no-discordant -k 200")
    //   - RSEM's `--bowtie2-k` default of 200, which Salmon's `--mimicStrictBT2`
    //     flag explicitly mirrors.
    // Users can override the default via `--bowtie2_align_k` or disable
    // multimapping entirely by setting it to 1.

    withName: '.*:ALIGN_BOWTIE2:BOWTIE2_ALIGN' {
        ext.args = {
            def args = [
                '--very-sensitive',
                '--no-discordant'
            ]

            if ((params.bowtie2_align_k as Integer) > 1) {
                args += ["-k ${params.bowtie2_align_k}"]
            }

            if (params.extra_bowtie2_align_args) {
                args += [params.extra_bowtie2_align_args]
            }

            // Read group tags - assembled once from samplesheet meta and pipeline params
            // Per-sample meta values take priority over global params
            def seqCenter   = meta.seq_center   ?: params.seq_center
            def seqPlatform = meta.seq_platform ?: params.seq_platform
            def rgParts = ["--rg-id ${meta.id}", "--rg SM:${meta.id}"]
            if (seqPlatform) rgParts << "--rg PL:${seqPlatform}"
            if (seqCenter) rgParts << "--rg CN:${seqCenter}"
            args += rgParts

            args.join(' ')
        }
        publishDir = [
            [
                path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/log" },
                mode: params.publish_dir_mode,
                pattern: '*.log'
            ],
            [
                path: { params.save_align_intermeds ? "${params.outdir}/${task.ext.publish_prefix}${params.aligner}" : params.outdir },
                mode: params.publish_dir_mode,
                pattern: '*.bam',
                saveAs: { filename -> params.save_align_intermeds ? filename : null }
            ],
            [
                path: { params.save_unaligned ? "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/unmapped" : params.outdir },
                mode: params.publish_dir_mode,
                pattern: '*.fastq.gz',
                saveAs: { filename -> params.save_unaligned ? filename : null }
            ]
        ]
    }
}
